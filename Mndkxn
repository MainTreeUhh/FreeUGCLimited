local b = a:CreateWindow("Obby for free ugc")
local c = b:AddFolder("Main")

c:AddToggle({
   text = "Auto Complete Obby",
   state = false,
   callback = function(d)
       if d then
           getgenv().obbyrun = true
           local e = game.Players.LocalPlayer

           getgenv().obbyloop1 = task.spawn(function()
               while getgenv().obbyrun do
                   for f = e.leaderstats.Stage.Value + 1, 100 do
                       if not getgenv().obbyrun then break end
                       e.Character:PivotTo(workspace.Checkpoints[f].CheckpointHitbox.CFrame)
                       task.wait(0.1)
                       e.Character.HumanoidRootPart.Anchored = true
                       repeat task.wait() until not getgenv().obbyrun or e.leaderstats.Stage.Value >= f
                       e.Character.HumanoidRootPart.Anchored = false
                   end
                   task.wait(5)
               end
           end)

           getgenv().obbyloop2 = task.spawn(function()
               while getgenv().obbyrun do
                   pcall(function()
                       firesignal(e.PlayerGui.Windows.Rebirth.Frame["Main body for Rebirth"]["Rebirth Button"].Activated)
                   end)
                   task.wait()
               end
           end)
       else
           getgenv().obbyrun = false
           local g = game.Players.LocalPlayer
           if g.Character and g.Character:FindFirstChild("HumanoidRootPart") then
               g.Character.HumanoidRootPart.Anchored = false
           end
       end
   end
})

